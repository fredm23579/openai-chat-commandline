# ─── AI Providers (at least one required) ─────────────────────────────────────

# OpenAI  →  https://platform.openai.com/api-keys
# Models: gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o3-mini
OPENAI_API_KEY=sk-...

# Anthropic (Claude)  →  https://console.anthropic.com/settings/keys
# Models: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001, …
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini  →  https://aistudio.google.com/app/apikey
# Models: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-1.5-pro, gemini-1.5-flash
# GOOGLE_API_KEY=AI...
# GEMINI_API_KEY=AI...   ← alias for GOOGLE_API_KEY

# Perplexity  →  https://www.perplexity.ai/settings/api
# Models: sonar, sonar-pro, sonar-reasoning, sonar-deep-research
# (Perplexity models include built-in real-time web search with citations.)
# PERPLEXITY_API_KEY=pplx-...

# X AI (Grok)  →  https://console.x.ai/
# Models: grok-3, grok-3-fast, grok-2-1212, grok-beta
# XAI_API_KEY=xai-...

# Groq  →  https://console.groq.com/keys
# Hosts Meta's Llama 3 models with extremely fast inference.
# Models: llama-3.3-70b-versatile, llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# GROQ_API_KEY=gsk_...


# ─── Web Search (optional but recommended) ────────────────────────────────────
# Without a search key every prompt skips the auto-search step.

# Tavily — designed for AI retrieval, generous free tier
# https://tavily.com
# TAVILY_API_KEY=tvly-...

# Brave Search — alternative
# https://api.search.brave.com/register
# BRAVE_API_KEY=BSA...


# ─── Custom OpenAI-compatible endpoint (optional) ─────────────────────────────
# Point the OpenAI client at Ollama, LM Studio, or any compatible local server.
# OPENAI_BASE_URL=http://localhost:11434/v1


# ─── Google Drive + Gmail (optional) ──────────────────────────────────────────
# No keys here — Google uses OAuth2. Follow the setup steps:
#
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create a project → enable "Google Drive API" and "Gmail API"
#   3. Create credential → OAuth 2.0 Client ID → Desktop app → Download JSON
#   4. Save the downloaded file as:  ~/.ai-chat/google-credentials.json
#
# On first use of /gdrive or /gmail the app opens your browser for consent.
# Tokens are cached automatically in ~/.ai-chat/google-tokens.json.
