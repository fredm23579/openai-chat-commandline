# ─── AI Providers (at least one required) ─────────────────────────────────────

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AI...

# Optional: point OpenAI client at a local / custom endpoint (Ollama, LM Studio, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1


# ─── Web Search (optional but recommended) ────────────────────────────────────
# Without a search key all prompts will skip the auto-search step.

# Tavily — best for AI-augmented search, generous free tier
# https://tavily.com
# TAVILY_API_KEY=tvly-...

# Brave Search — alternative
# https://api.search.brave.com/register
# BRAVE_API_KEY=BSA...
